# Longrise Admin Frontend - Staging/Production Environment Template
# 이 파일은 배포 스크립트가 .env.stage 생성 시 참고하는 템플릿입니다

# API Configuration - 배포 시점에 실제 값으로 교체됨
VITE_ADMIN_API_BASE_URL=/api/v1
VITE_ENVIRONMENT=production
VITE_BUILD_UID=prod-admin-001

# Application Configuration
VITE_APP_NAME="Longrise Admin Panel"
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="Administrative Control Panel"

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG_PANEL=false

# Security
VITE_ENABLE_CSRF=true
VITE_TOKEN_STORAGE_KEY=longrise_admin_token

# UI Settings
VITE_DEFAULT_THEME=dark
VITE_ENABLE_ANIMATIONS=true

# Production Settings
VITE_LOG_LEVEL=info

# Admin Specific
VITE_ADMIN_SESSION_TIMEOUT=3600000
VITE_AUDIT_LOG_REFRESH_INTERVAL=10000
