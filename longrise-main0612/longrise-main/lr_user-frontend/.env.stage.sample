# Longrise User Frontend - Staging/Production Environment Template
# 이 파일은 배포 스크립트가 .env.stage 생성 시 참고하는 템플릿입니다

# API Configuration - 배포 시점에 실제 값으로 교체됨
VITE_API_BASE_URL=/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_ENVIRONMENT=production
VITE_BUILD_UID=prod-build-001

# Application Configuration
VITE_APP_NAME="Longrise AI"
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="Crypto Investment Platform"

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_PANEL=false

# Security
VITE_ENABLE_CSRF=true
VITE_TOKEN_STORAGE_KEY=longrise_token

# UI Settings
VITE_DEFAULT_THEME=dark
VITE_ENABLE_ANIMATIONS=true

# Performance Settings
VITE_PERFORMANCE_MODE=auto
VITE_LOCAL_DEV_MODE=false
VITE_ENABLE_CANVAS_ANIMATIONS=true
VITE_ENABLE_CSS_ANIMATIONS=true
VITE_ENABLE_REALTIME_UPDATES=true
VITE_ENABLE_BLUR_EFFECTS=true
VITE_PARTICLE_COUNT_MULTIPLIER=1.0

# Production Settings
VITE_LOG_LEVEL=info
