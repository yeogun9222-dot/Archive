# jake-agent 환경변수 템플릿
# 사용법: 이 파일을 복사해서 .env 로 저장한 뒤, 아래 안내대로 값을 채운다.
#   cp .env.example .env
# .env 자체는 .gitignore에 의해 git에 올라가지 않는다 (의도된 보안 조치).
# API 키는 모두 재발급 가능하므로 분실해도 괜찮다 — 발급처만 알면 된다.

# ── 필수 ─────────────────────────────────────────────
# Claude API 키. 발급: https://console.anthropic.com → Settings → API Keys → Create Key
ANTHROPIC_API_KEY=

# 텔레그램 봇 토큰. 발급: 텔레그램에서 @BotFather 검색 → /newbot → 안내대로 봇 이름 입력 → 토큰 발급
TELEGRAM_BOT_TOKEN=
# 대표님 개인 텔레그램 chat id. 확인: 텔레그램에서 @userinfobot 검색 → 대화 시작하면 ID 표시됨
TELEGRAM_CHAT_ID=

# Notion Integration 키 3종. 발급: https://www.notion.so/my-integrations → New integration → Internal Integration Secret 복사
# 발급 후 반드시 해당 Notion 페이지 우측 상단 "..." → Connections → 방금 만든 Integration 연결(Share) 필요 — 안 하면 401 에러
NOTION_API_KEY=
NOTION_ARCHITECTS_KEY=
NOTION_GUIDE_KEY=

# GitHub Personal Access Token. 발급: https://github.com/settings/tokens → Generate new token (classic) → repo 권한 체크
GITHUB_TOKEN=
GITHUB_REPO=yeogun9222-dot/Archive

# ── 선택 (없어도 jake-agent 기본 기능은 동작) ─────────────────
# 텔레그램 그룹 채팅 연동용 (그룹 ID는 봇을 그룹에 초대 후 getUpdates API로 확인)
TELEGRAM_GROUP_IDS=
TELEGRAM_RESPONSE_GROUP_IDS=

# RapidAPI 키 (특정 외부 데이터 도구용). 발급: https://rapidapi.com → 가입 → 사용할 API 구독 → 키 확인
RAPIDAPI_KEY=
# Kiwi(항공 검색 등) API 키. 발급: https://tequila.kiwi.com
KIWI_API_KEY=

# TimeTree 캘린더 연동. 발급: TimeTree 개발자 포털에서 액세스 토큰 발급, 캘린더 ID는 공유 링크에서 확인
TIMETREE_ACCESS_TOKEN=
TIMETREE_CALENDAR_ID=

# Google Docs/Sheets/Slides/Gmail/Calendar 연동.
# 발급: Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 클라이언트 ID 생성 → credentials.json 다운로드
# credentials.json, token.json 파일을 base64로 인코딩해서 아래에 입력 (PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("credentials.json")))
GOOGLE_CREDENTIALS_B64=
GOOGLE_TOKEN_B64=
GOOGLE_SHARED_CALENDAR_ID=

# Brave Search API 키. 발급: https://brave.com/search/api
BRAVE_API_KEY=

# GCP 비용 추적용 (BigQuery billing export). 서비스 계정 키를 base64 인코딩해서 입력.
# 발급: GCP Console → IAM 및 관리자 → 서비스 계정 → 키 생성(JSON) → base64 인코딩
GCP_BILLING_KEY_B64=
GCP_BILLING_PROJECT=rugged-reality-500602-d7
GCP_BILLING_DATASET=billing_export
GCP_BILLING_TABLE=

# Anthropic Team 플랜 전환 시에만 사용 (현재 Individual Org라 미발급 상태, 보류 항목)
ANTHROPIC_ADMIN_KEY=
